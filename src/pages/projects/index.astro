---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { projects } from '../../data/projects';

const featuredProjects = projects.filter((project) => project.featuredRank);
const otherProjects = projects.filter((project) => !project.featuredRank);
---

<BaseLayout title="Projects | Cat5Dog2 Portfolio" description="Cat5Dog2の個人開発・実績ページ一覧です。">
  <main class="l-section">
    <div class="l-container">
      <div class="project-collection">
        <SectionHeading
          eyebrow="Featured Projects"
          title="注力プロジェクト"
          lead="仕様駆動開発で、設計から運用まで一貫して取り組んだ2作品です。"
        />
        <div class="l-grid l-grid--2">
          {featuredProjects.map((project) => <ProjectCard project={project} />)}
        </div>
      </div>

      <div class="project-collection">
        <SectionHeading
          eyebrow="Other Projects"
          title="その他のプロジェクト"
          lead="仕様駆動開発で、ドメイン設計や外部連携の検証に取り組んだプロジェクトです。"
        />
        <div class="l-grid l-grid--2">
          {otherProjects.map((project) => <ProjectCard project={project} />)}
        </div>
      </div>
    </div>
  </main>
</BaseLayout>
