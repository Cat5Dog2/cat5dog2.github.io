---
import BaseLayout from '../../layouts/BaseLayout.astro';
import SectionHeading from '../../components/SectionHeading.astro';
import ProjectCard from '../../components/ProjectCard.astro';
import { projects } from '../../data/projects';

const featuredProjects = projects.filter((project) => project.featuredRank);
const otherProjects = projects.filter((project) => !project.featuredRank);
---

<BaseLayout
  title="Projects | Cat5Dog2 Portfolio"
  description="Cat5Dog2の個人開発・実績ページ一覧です。"
  breadcrumbs={[
    { name: 'Home', path: '' },
    { name: 'Projects', path: 'projects/' },
  ]}
>
  <main id="main" class="l-section">
    <div class="l-container">
      <div class="project-collection">
        <SectionHeading
          as="h1"
          eyebrow="Featured Projects"
          title="注力プロジェクト"
          lead="要件・受け入れ条件の文書化から運用まで、一貫して取り組んだ2作品です。"
        />
        <div class="l-grid l-grid--2">
          {featuredProjects.map((project) => <ProjectCard project={project} as="h2" />)}
        </div>
      </div>

      <div class="project-collection">
        <SectionHeading
          eyebrow="Other Projects"
          title="その他のプロジェクト"
          lead="実務で得たドメイン知識を題材に、設計と外部連携の検証に取り組んだプロジェクトです。"
        />
        <div class="l-grid l-grid--2">
          {otherProjects.map((project) => <ProjectCard project={project} />)}
        </div>
      </div>
    </div>
  </main>
</BaseLayout>
