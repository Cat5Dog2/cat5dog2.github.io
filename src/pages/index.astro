---
import BaseLayout from '../layouts/BaseLayout.astro';
import SectionHeading from '../components/SectionHeading.astro';
import ProjectCard from '../components/ProjectCard.astro';
import MetricCard from '../components/MetricCard.astro';
import SkillCard from '../components/SkillCard.astro';
import { projects } from '../data/projects';
import { withBase } from '../utils/paths';

const featuredProjects = projects.filter((project) => project.featuredRank);
const otherProjects = projects.filter((project) => !project.featuredRank);
---

<BaseLayout>
  <main>
    <section class="hero">
      <div class="l-container hero__grid">
        <div>
          <p class="eyebrow">Web Engineer — .NET / TypeScript / Azure</p>
          <h1 class="hero__title">
            仕様書から、
            <span>本番環境まで。</span>
          </h1>
          <p class="lead">
            要件定義・受け入れ条件の文書化から、実装、E2Eテスト、CI/CD、クラウド運用設計まで。Web集客・EC・業務システム開発の実務で得たドメイン知識を、.NET・TypeScript・Azureでのプロダクト開発に活かしています。
          </p>
          <div class="hero__actions">
            <a class="button button--primary" href="#projects">実績を見る</a>
            <a class="button button--ghost" href="https://github.com/Cat5Dog2" target="_blank" rel="noreferrer">GitHub</a>
          </div>
        </div>

        <aside class="hero-panel" aria-label="強みの要約">
          <div class="hero-panel__list">
            <div class="hero-panel__item">
              <strong>Now</strong>
              <span>グローバルIT企業でインターン（技術検証・プロジェクト推進）</span>
            </div>
            <div class="hero-panel__item">
              <strong>Stack</strong>
              <span>.NET / TypeScript / React / Azure / Docker</span>
            </div>
            <div class="hero-panel__item">
              <strong>Delivery</strong>
              <span>仕様駆動開発：要件・設計・受け入れ条件 → 実装 → 検証</span>
            </div>
            <div class="hero-panel__item">
              <strong>Web Marketing</strong>
              <span>SEO / Paid Search Advertising</span>
            </div>
          </div>
        </aside>
      </div>
    </section>

    <section class="l-section--compact">
      <div class="l-container l-grid l-grid--3">
        <MetricCard value="2本" label="クラウドで公開中のWebアプリ" note="Azure App Service / Firebase + Cloud Run。デモ利用可" />
        <MetricCard value="4/4" label="全リポジトリでCI/CDを運用" note="GitHub Actions / Playwright E2E / デプロイ後スモークテスト" />
        <MetricCard value="docs/" label="要件・設計・テスト仕様を文書化" note="要件定義・基本設計・受け入れ条件を各リポジトリで公開" />
      </div>
    </section>

    <section id="projects" class="l-section">
      <div class="l-container">
        <div class="project-collection">
          <SectionHeading
            eyebrow="Featured Projects"
            title="注力プロジェクト"
            lead="仕様駆動開発で、設計から運用まで一貫して取り組んだ2作品です。詳細ページで課題・実装・技術判断を確認できます。"
          />
          <div class="l-grid l-grid--2">
            {featuredProjects.map((project) => <ProjectCard project={project} />)}
          </div>
        </div>

        <div class="project-collection">
          <SectionHeading
            eyebrow="Other Projects"
            title="その他のプロジェクト"
            lead="仕様を先に整理し、実務で得たドメイン知識を.NET開発に活かしたプロジェクトです。"
          />
          <div class="l-grid l-grid--2">
            {otherProjects.map((project) => <ProjectCard project={project} />)}
          </div>
        </div>
      </div>
    </section>

    <section id="skills" class="l-section u-surface-soft">
      <div class="l-container">
        <SectionHeading
          eyebrow="Skills"
          title="技術スタック"
          lead="ケイパビリティ別に整理しています。実務と個人開発の両方を含みます。"
        />
        <div class="l-grid l-grid--3">
          <SkillCard
            category="Backend & Cloud"
            title="サーバーサイド / インフラ"
            note="業務システム開発・個人プロダクトで使用"
            skills={['C#', 'ASP.NET Core', 'Ruby on Rails', 'PHP', 'Docker', 'Azure', 'Firebase', 'SQL Server', 'PostgreSQL']}
          />
          <SkillCard
            category="Frontend & UI"
            title="フロントエンド / UI"
            note="EC・メディア・業務画面・SPAで使用"
            skills={['TypeScript', 'React', 'Blazor', 'HTML/CSS', 'JavaScript', 'Vite', 'WordPress', 'jQuery']}
          />
          <SkillCard
            category="DevOps & Process"
            title="品質管理 / チーム推進"
            note="自動テスト・CI/CD・プロジェクト管理を実践"
            skills={['仕様駆動開発', 'GitHub Actions', 'Playwright E2E', 'CI/CD', 'Git', '要件定義', 'DB設計', 'チームリード', 'アジャイル']}
          />
        </div>
      </div>
    </section>

    <section class="l-section">
      <div class="l-container l-grid l-grid--2">
        <div>
          <SectionHeading
            eyebrow="Career"
            title="Web運営から開発・IT実務へ領域を拡大"
            lead="メディア運営からWeb制作、EC、受託開発と進み、現在はグローバルIT企業でインターン中です。"
          />
          <a class="button button--ghost" href={withBase('career/')}>職務要約を見る</a>
        </div>
        <div class="note-card">
          <p class="eyebrow">This Site is Code</p>
          <h3>このポートフォリオ自体がコード品質のサンプルです</h3>
          <p class="u-muted">
            CSS Cascade Layersによる依存制御、Custom Propertiesによるデザイントークン、セマンティックHTML。Astroの静的生成で高速表示を実現しています。
          </p>
          <a class="button button--ghost" href="https://github.com/Cat5Dog2/cat5dog2.github.io" target="_blank" rel="noreferrer" style="margin-top: 0.75rem;">ソースコードを見る</a>
        </div>
      </div>
    </section>

    <section id="contact" class="l-section contact-section">
      <div class="l-container contact-card">
        <div>
          <p class="eyebrow">Contact</p>
          <h2>お気軽にご連絡ください</h2>
          <p>ご連絡はメールかXのDMにて、個人開発についてはGitHubからお気軽にどうぞ。</p>
        </div>
        <div class="contact-card__actions">
          <a class="button button--primary" href="mailto:cat5dog2.tskhrcm@gmail.com">メールを送る</a>
          <a class="button button--ghost" href="https://x.com/Cat5Dog2" target="_blank" rel="noreferrer">XでDMを送る</a>
          <a class="button button--ghost" href="https://github.com/Cat5Dog2" target="_blank" rel="noreferrer">GitHubを見る</a>
        </div>
      </div>
    </section>
  </main>
</BaseLayout>
