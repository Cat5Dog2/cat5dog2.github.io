---
import type { Project } from '../data/projects';
import { withBase } from '../utils/paths';

interface Props {
  project: Project;
  /** 配置先セクションの見出し階層に合わせて指定する */
  as?: 'h2' | 'h3';
}

const { project, as = 'h3' } = Astro.props as Props;
const Heading = as;
---

<a
  class:list={['project-card', { 'project-card--featured': project.featuredRank }]}
  href={withBase(project.slug)}
>
  <div class="project-card__meta">
    <p class="eyebrow">
      {project.featuredRank ? `Featured Project 0${project.featuredRank}` : 'Project'}
    </p>
    <span class="project-card__status">{project.status}</span>
  </div>
  <div class="l-stack">
    <Heading class="project-card__title">{project.title}</Heading>
    <p class="project-card__summary">{project.summary}</p>
    <p class="project-card__role"><strong>担当:</strong> {project.role}</p>
    <p class="project-card__stage"><strong>現在:</strong> {project.stage}</p>
  </div>
  <ul class="tag-list project-card__tags" role="list" aria-label={`${project.title} の特徴`}>
    {project.metrics.map((metric) => <li class="tag">{metric}</li>)}
  </ul>
</a>
