---
import type { Project } from '../data/projects';
import { withBase } from '../utils/paths';

interface Props {
  project: Project;
}

const { project } = Astro.props;
---

<a
  class:list={['project-card', { 'project-card--featured': project.featuredRank }]}
  href={withBase(project.slug)}
>
  <div class="project-card__meta">
    <p class="eyebrow">
      {project.featuredRank ? `Featured Project 0${project.featuredRank}` : 'Project'}
    </p>
    <span class="project-card__status">{project.status}</span>
  </div>
  <div class="l-stack">
    <h3 class="project-card__title">{project.title}</h3>
    <p class="project-card__summary">{project.summary}</p>
    <p class="project-card__role"><strong>担当:</strong> {project.role}</p>
    <p class="project-card__stage"><strong>現在:</strong> {project.stage}</p>
  </div>
  <div class="tag-list" aria-label={`${project.title} の特徴`}>
    {project.metrics.map((metric) => <span class="tag">{metric}</span>)}
  </div>
</a>
