---
import { withBase } from '../utils/paths';

const navigation = [
  { href: withBase('#projects'), label: 'Projects' },
  { href: withBase('#skills'), label: 'Skills' },
  { href: withBase('career/'), label: 'Career' },
  { href: withBase('projects/'), label: 'All Projects' },
  { href: withBase('#contact'), label: 'Contact' },
];
---

<header class="site-header">
  <div class="l-container site-header__inner">
    <a class="site-logo" href={withBase()} aria-label="Cat5Dog2 Portfolio ホーム">
      <span class="site-logo__mark" aria-hidden="true">C5D2</span>
      <span>Cat5Dog2</span>
    </a>
    <nav class="site-nav" aria-label="グローバルナビゲーション">
      {navigation.map((item) => <a href={item.href}>{item.label}</a>)}
      <a href="https://github.com/Cat5Dog2" target="_blank" rel="noreferrer">GitHub</a>
    </nav>
    <details class="mobile-menu">
      <summary>Menu</summary>
      <nav class="mobile-menu__nav" aria-label="モバイルナビゲーション">
        {navigation.map((item) => <a href={item.href}>{item.label}</a>)}
        <a href="https://github.com/Cat5Dog2" target="_blank" rel="noreferrer">GitHub</a>
      </nav>
    </details>
  </div>
</header>

{/* details/summaryは開閉セマンティクスの通知とJS無効時の動作をネイティブに持つ。
    足りない挙動（選択後に閉じる・Escape・メニュー外操作で閉じる）だけをJSで補う。
    同一ページ内アンカーやtarget="_blank"はページ遷移が起きず開いたままになるため */}
<script is:inline>
  (() => {
    const menu = document.querySelector('.mobile-menu');
    const summary = menu && menu.querySelector('summary');
    if (!menu || !summary) return;

    const close = () => menu.removeAttribute('open');

    // リンク選択で閉じる（同一ページ内アンカー・別タブで開くリンクを含む）
    menu.addEventListener('click', (event) => {
      if (event.target instanceof Element && event.target.closest('a')) close();
    });

    // Escapeで閉じ、フォーカスをトグルへ戻す
    menu.addEventListener('keydown', (event) => {
      if (event.key === 'Escape' && menu.open) {
        close();
        summary.focus();
      }
    });

    // Tab移動でメニューの外へ出たら閉じる（隠れた要素へフォーカスが残らない）
    menu.addEventListener('focusout', (event) => {
      if (menu.open && event.relatedTarget instanceof Node && !menu.contains(event.relatedTarget)) {
        close();
      }
    });

    // メニュー外のクリック・タップで閉じる
    document.addEventListener('click', (event) => {
      if (menu.open && event.target instanceof Node && !menu.contains(event.target)) {
        close();
      }
    });
  })();
</script>
