---
interface Props {
  eyebrow: string;
  title: string;
  lead?: string;
  headingId?: string;
}

const { eyebrow, title, lead, headingId } = Astro.props;
---

<div class="section-heading">
  <p class="section-heading__eyebrow">{eyebrow}</p>
  <h2 id={headingId} class="section-heading__title">{title}</h2>
  {lead && <p class="section-heading__lead">{lead}</p>}
</div>
