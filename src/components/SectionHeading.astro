---
interface Props {
  eyebrow: string;
  title: string;
  lead?: string;
}

const { eyebrow, title, lead } = Astro.props;
---

<div class="section-heading">
  <p class="section-heading__eyebrow">{eyebrow}</p>
  <h2 class="section-heading__title">{title}</h2>
  {lead && <p class="section-heading__lead">{lead}</p>}
</div>
