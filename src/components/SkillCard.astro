---
interface Props {
  title: string;
  skills: string[];
  category?: string;
  note?: string;
}

const { title, skills, category, note } = Astro.props;
---

<section class="skill-card">
  {category && <p class="skill-card__category">{category}</p>}
  <h3 class="skill-card__title">{title}</h3>
  {note && <p class="skill-card__note">{note}</p>}
  <ul class="tag-list" role="list">
    {skills.map((skill) => <li class="tag">{skill}</li>)}
  </ul>
</section>
