---
import BaseLayout from './BaseLayout.astro';

const { frontmatter } = Astro.props;
const tags = frontmatter.tags ?? [];

const featuredRank = frontmatter.featuredRank;

const breadcrumbs = [
  { name: 'Home', path: '' },
  { name: 'Projects', path: 'projects/' },
  { name: frontmatter.title, path: Astro.url.pathname },
];
---

<BaseLayout
  title={`${frontmatter.title} | Cat5Dog2 Portfolio`}
  description={frontmatter.description}
  ogType="article"
  breadcrumbs={breadcrumbs}
>
  <main id="main">
    <header class="project-hero">
      <div class="l-container">
        <p class="eyebrow">{featuredRank ? `Featured Project 0${featuredRank}` : 'Project'}</p>
        <h1 class="project-hero__title">{frontmatter.title}</h1>
        <p class="project-hero__summary">{frontmatter.description}</p>
        {frontmatter.stage && <p class="project-hero__stage">現在の状態: {frontmatter.stage}</p>}
        <div class="project-hero__meta">
          <ul class="tag-list" role="list" aria-label="使用技術">
            {tags.map((tag: string) => <li class="tag">{tag}</li>)}
          </ul>
        </div>

      </div>
    </header>

    <div class="l-container">
      <article class="markdown-body">
        <slot />
      </article>
    </div>
  </main>
</BaseLayout>
